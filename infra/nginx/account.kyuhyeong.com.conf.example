# account.kyuhyeong.com 리버스 프록시 (호스트 nginx, /etc/nginx/conf.d/ 에 배치).
#
# 기존 game/itsm 과 동일한 certbot-managed 패턴:
#   1. DNS A 레코드: account.kyuhyeong.com → VPS IP
#   2. docker compose 운영 stack 기동 (account-api 가 127.0.0.1:8085 노출)
#   3. 본 server 블록을 /etc/nginx/conf.d/account.kyuhyeong.com.conf 로 두고
#      sudo nginx -t && sudo systemctl reload nginx
#   4. sudo certbot --nginx -d account.kyuhyeong.com
#      → certbot 이 listen 443 ssl + 인증서 경로 + 80→443 리다이렉트 server 블록을 자동 추가
#      (game/itsm 도 동일하게 생성돼 있음)
#
# 호스트 포트 8085 = 기존 8080 portfolio / 8081 shop / 8082 game / 8083 api / 8084 itsm
# 다음 빈 포트. docker-compose.prod.yml 의 published 포트와 일치해야 한다.

server {
    server_name account.kyuhyeong.com;
    location /.well-known/acme-challenge/ { root /var/www/certbot; }

    # 영수증 업로드(multipart) — Spring 의 spring.servlet.multipart.max-file-size(10MB)와 맞춤.
    # nginx 기본값 1MB 면 영수증 업로드가 413 으로 막힌다.
    client_max_body_size 12m;

    location / {
        proxy_pass         http://127.0.0.1:8085;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        # SSR: 세션 쿠키 / formLogin 302 리다이렉트가 https 로 생성되도록 (forward-headers-strategy).
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Connection        "";

        # 영수증 분석은 Claude API 호출 포함 — 평균 5~15s, 여유 두고 90s.
        proxy_connect_timeout 10s;
        proxy_send_timeout    90s;
        proxy_read_timeout    90s;
    }
}
