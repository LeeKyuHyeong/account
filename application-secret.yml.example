# application-secret.yml.example
#
# 로컬 개발용 시크릿 템플릿. 본 파일은 커밋 OK (값 없음).
#
# 사용법:
#   1. 본 파일을 같은 위치에 application-secret.yml 로 복사
#   2. 아래 값들을 실제 값으로 교체
#   3. application-secret.yml 은 .gitignore 로 자동 차단됨 — 절대 직접 커밋하지 말 것
#
# 로드 메커니즘:
#   account-api/src/main/resources/application.yml 의
#     spring.config.import: optional:file:./application-secret.yml
#   이 본 파일을 자동으로 병합한다. 프로젝트 루트에서 ./gradlew :account-api:bootRun
#   할 때 동작 (working directory 가 프로젝트 루트).
#
# 운영 (Week 6+) 에서는 본 파일 대신 환경변수로 주입한다.

account:
  claude:
    # https://console.anthropic.com → Settings → API Keys 에서 발급 (형식: sk-ant-...)
    # ⚠ Settings → Billing → Spend limits 로 월 한도 ($10 권장) 사전 설정
    api-key: <PASTE-ANTHROPIC-KEY-HERE>

  # ─── 로컬 개발 전용: 첫 카카오 로그인을 기존 시드 유저에 연결 ───
  # 운영에서는 비워둔다 (매핑 없으면 신규 유저 생성 + 온보딩 경로).
  # 사용법: 카카오 로그인을 1회 시도하면 서버 로그에
  #   "Kakao login: providerUserId=XXXXXXXXXX, nickname=..." 가 찍힌다.
  #   그 providerUserId 를 아래 key 로, 연결할 시드 유저 email 을 value 로 넣고 재기동하면
  #   해당 카카오 계정이 그 시드 유저(예: owner1 의 22개 카테고리/거래)로 로그인된다.
  dev:
    kakao-links: {}
    # 예시:
    # kakao-links:
    #   "1234567890": "owner1@example.com"
    #   "9876543210": "owner2@example.com"

# ─── 카카오 OAuth2 (https://developers.kakao.com) ───
# 내 애플리케이션 → 앱 키 → "REST API 키" = client-id.
# 보안 → "Client Secret" 을 사용함으로 설정 후 코드 발급 = client-secret.
#   (Client Secret 을 "사용 안 함" 으로 두는 경우: application.yml 의 kakao registration 에서
#    client-secret 줄을 제거하고 client-authentication-method 를 none 으로 바꾼다.)
# 카카오 로그인 → Redirect URI 에 다음을 등록: http://localhost:8085/login/oauth2/code/kakao
#   (운영 도메인도 동일 경로로 추가). 동의항목에서 "닉네임(profile_nickname)" 필수 동의로 설정.
KAKAO_CLIENT_ID: <PASTE-KAKAO-REST-API-KEY-HERE>
KAKAO_CLIENT_SECRET: <PASTE-KAKAO-CLIENT-SECRET-HERE>
# 카카오톡 초대 공유용 JavaScript 키 (앱 키 > JavaScript 키 — REST API 키와 다름).
# [플랫폼 > Web] 에 http://localhost:8085 도메인 등록 필요. 비워두면 공유 버튼이 숨겨진다.
KAKAO_JS_KEY: <PASTE-KAKAO-JAVASCRIPT-KEY-HERE>
