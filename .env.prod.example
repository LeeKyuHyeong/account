# .env.prod.example
#
# 운영 docker compose stack 에 주입할 환경변수 템플릿.
#
# 사용법 (VPS 에서):
#   1. cp .env.prod.example .env.prod
#   2. 아래 값들을 실제 값으로 교체 (특히 ?required 표시된 시크릿)
#   3. chmod 600 .env.prod  (root 만 읽기 — 다른 사용자에게 노출 차단)
#   4. docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# .env.prod 자체는 .gitignore 로 차단됨 (`.env*` 패턴). 절대 커밋 X.

# ─── DB ───
# 운영 비밀번호. 로컬과 다른 강한 값으로. (예: pwgen -s 32 1)
ACCOUNT_DB_ROOT_PASSWORD=<paste-strong-random>
ACCOUNT_DB_PASSWORD=<paste-strong-random>
ACCOUNT_DB_NAME=account
ACCOUNT_DB_USER=account

# ─── Claude API ───
# https://console.anthropic.com → API Keys 에서 발급 (sk-ant-...)
# ⚠ Billing → Spend limits 로 월 한도 ($10 권장) 사전 설정
ACCOUNT_CLAUDE_API_KEY=<paste-anthropic-key>
